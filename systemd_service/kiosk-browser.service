[Unit]
Description=AI Camera Kiosk Browser
After=aicamera_v1.3.service
Wants=aicamera_v1.3.service
Requires=graphical-session.target

[Service]
Type=simple
User=camuser
Group=camuser
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/camuser/.Xauthority
WorkingDirectory=/home/camuser/aicamera

# Wait for the web service to be ready before starting browser
ExecStartPre=/bin/bash -c 'until curl -s http://localhost/ >/dev/null 2>&1; do sleep 2; done'
ExecStart=/bin/bash -c 'sleep 5 && chromium-browser --kiosk --disable-web-security --disable-features=VizDisplayCompositor --no-first-run --no-default-browser-check --disable-background-timer-throttling --disable-backgrounding-occluded-windows --disable-renderer-backgrounding --disable-features=TranslateUI --disable-ipc-flooding-protection --disable-dev-shm-usage --disable-gpu --no-sandbox --autoplay-policy=no-user-gesture-required http://localhost/'

# Restart policy
Restart=always
RestartSec=10

# Kill the browser process on service stop
KillMode=mixed
KillSignal=SIGTERM
TimeoutStopSec=10

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=kiosk-browser

[Install]
WantedBy=graphical-session.target
