{
  "name": "aicamera-server",
  "version": "2.0.0",
  "description": "AI Camera Server - Data ingestion and management server",
  "main": "dist/src/main.js",
  "scripts": {
    "build:frontend": "npm --prefix ./frontend install && npm --prefix ./frontend run build",
    "build": "npm run build:frontend && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "dev:full": "concurrently -k -n \"SERVER,WEB\" -c \"cyan,green\" \"npm run start:dev\" \"npm --prefix ./frontend run dev\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "keywords": [
    "ai-camera",
    "lpr-detection",
    "edge-computing",
    "nodejs",
    "python",
    "monorepo"
  ],
  "author": "AI Camera Team",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/serve-static": "^4.0.1",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/platform-socket.io": "^10.4.0",
    "@nestjs/throttler": "^5.2.0",
    "@nestjs/websockets": "^10.4.0",
    "@prisma/client": "^6.14.0",
    "@types/bcryptjs": "^2.4.6",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "moment": "^2.29.4",
    "morgan": "^1.10.0",
    "mqtt": "^5.14.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "prisma": "^6.14.0",
    "rate-limiter-flexible": "^7.2.0",
    "redis": "^4.6.10",
    "sequelize": "^6.35.1",
    "sharp": "^0.32.6",
    "socket.io": "^4.7.4",
    "ssh2": "^1.15.0",
    "ssh2-sftp-client": "^12.0.1",
    "superagent": "^10.2.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^10.4.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^2.0.12",
    "eslint": "^8.55.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/popwandee/aicamera.git"
  }
}
