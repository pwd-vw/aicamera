{
  "version": "1.0.0",
  "description": "Socket.IO event specifications for AI Camera real-time communication",
  "events": {
    "camera": {
      "register": {
        "direction": "client_to_server",
        "description": "Register a camera with the server",
        "data": {
          "camera_id": "string",
          "name": "string",
          "location": {
            "latitude": "number",
            "longitude": "number",
            "address": "string"
          },
          "status": "string",
          "configuration": "object"
        },
        "response": {
          "success": "boolean",
          "message": "string",
          "camera_id": "string"
        }
      },
      "registered": {
        "direction": "server_to_client",
        "description": "Confirmation of camera registration",
        "data": {
          "success": "boolean",
          "message": "string",
          "camera_id": "string"
        }
      },
      "registration_error": {
        "direction": "server_to_client",
        "description": "Camera registration error",
        "data": {
          "success": "boolean",
          "error": "string"
        }
      },
      "connected": {
        "direction": "server_to_client",
        "description": "Notification when a camera connects",
        "data": {
          "camera_id": "string",
          "location": "object",
          "timestamp": "string"
        }
      },
      "disconnected": {
        "direction": "server_to_client",
        "description": "Notification when a camera disconnects",
        "data": {
          "camera_id": "string",
          "timestamp": "string"
        }
      },
      "status": {
        "direction": "client_to_server",
        "description": "Camera status update",
        "data": {
          "status": "string",
          "cpu_usage": "number",
          "memory_usage": "number",
          "disk_usage": "number",
          "temperature": "number",
          "uptime_seconds": "number",
          "last_detection_at": "string"
        }
      },
      "status_update": {
        "direction": "server_to_client",
        "description": "Broadcast camera status update",
        "data": {
          "camera_id": "string",
          "status": "string",
          "timestamp": "string"
        }
      }
    },
    "detection": {
      "data": {
        "direction": "client_to_server",
        "description": "Submit real-time detection data",
        "data": {
          "license_plate": "string",
          "confidence": "number",
          "image_url": "string",
          "location": {
            "latitude": "number",
            "longitude": "number"
          },
          "vehicle_info": {
            "make": "string",
            "model": "string",
            "color": "string",
            "type": "string"
          },
          "timestamp": "string"
        }
      },
      "received": {
        "direction": "server_to_client",
        "description": "Confirmation of detection data receipt",
        "data": {
          "success": "boolean",
          "message": "string"
        }
      },
      "error": {
        "direction": "server_to_client",
        "description": "Detection data processing error",
        "data": {
          "success": "boolean",
          "error": "string"
        }
      },
      "new": {
        "direction": "server_to_client",
        "description": "Broadcast new detection to dashboard clients",
        "data": {
          "camera_id": "string",
          "detection": "object",
          "timestamp": "string"
        }
      }
    },
    "dashboard": {
      "connect": {
        "direction": "client_to_server",
        "description": "Dashboard client connection",
        "data": {
          "client_type": "string",
          "version": "string"
        }
      },
      "status": {
        "direction": "server_to_client",
        "description": "Current system status for dashboard",
        "data": {
          "cameras": "array",
          "detections_today": "number",
          "system_status": "string",
          "last_updated": "string"
        }
      }
    },
    "system": {
      "ping": {
        "direction": "client_to_server",
        "description": "Connection health check",
        "data": {}
      },
      "pong": {
        "direction": "server_to_client",
        "description": "Connection health response",
        "data": {
          "timestamp": "string"
        }
      }
    }
  },
  "rooms": {
    "camera:{camera_id}": "Camera-specific room for targeted messages",
    "dashboard": "Dashboard clients room for system-wide updates",
    "analytics": "Analytics clients room for real-time analytics"
  },
  "error_codes": {
    "E001": "Invalid camera ID",
    "E002": "Camera not registered",
    "E003": "Invalid detection data",
    "E004": "Database connection error",
    "E005": "Authentication required",
    "E006": "Rate limit exceeded",
    "E007": "Server maintenance mode"
  }
}
