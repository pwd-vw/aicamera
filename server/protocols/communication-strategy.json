{
  "version": "1.0.0",
  "description": "AI Camera Communication Strategy - Multi-layered approach for reliability",
  "communication_layers": {
    "primary": {
      "protocol": "websocket",
      "description": "Real-time bidirectional communication",
      "priority": 1,
      "use_cases": [
        "Real-time detection data",
        "Camera status updates",
        "Live monitoring",
        "Configuration updates",
        "Health checks"
      ],
      "advantages": [
        "Low latency",
        "Bidirectional",
        "Real-time",
        "Efficient for frequent updates"
      ],
      "fallback_to": "rest_api"
    },
    "backup": {
      "protocol": "rest_api",
      "description": "HTTP REST API for reliable communication",
      "priority": 2,
      "use_cases": [
        "Detection data submission",
        "Camera registration",
        "Configuration retrieval",
        "Analytics queries",
        "Bulk data operations"
      ],
      "advantages": [
        "Reliable",
        "Stateless",
        "Easy to debug",
        "Standard HTTP"
      ],
      "fallback_to": "mqtt"
    },
    "fallback": {
      "protocol": "mqtt",
      "description": "Lightweight messaging for poor network conditions",
      "priority": 3,
      "use_cases": [
        "Critical alerts",
        "Status updates",
        "Small data packets",
        "Offline message queuing"
      ],
      "advantages": [
        "Lightweight",
        "Works on poor networks",
        "Message persistence",
        "QoS levels"
      ],
      "fallback_to": "file_sync"
    }
  },
  "image_transfer": {
    "protocol": "sftp_rsync",
    "description": "Secure file transfer for captured images",
    "source": "captured_images/ (edge)",
    "destination": "image_storage/ (server)",
    "configuration": {
      "sftp": {
        "port": 22,
        "username": "aicamera",
        "key_based_auth": true,
        "compression": true
      },
      "rsync": {
        "options": [
          "-avz",
          "--delete",
          "--progress",
          "--compress",
          "--partial"
        ],
        "exclude_patterns": [
          "*.tmp",
          "*.temp",
          "*.lock"
        ],
        "retry_attempts": 3,
        "retry_delay": 30
      }
    },
    "schedule": {
      "frequency": "every_5_minutes",
      "batch_size": 100,
      "max_file_size": "10MB"
    }
  },
  "connection_management": {
    "health_check": {
      "websocket": {
        "interval": 30,
        "timeout": 10,
        "retry_attempts": 3
      },
      "rest_api": {
        "interval": 60,
        "timeout": 15,
        "retry_attempts": 5
      },
      "mqtt": {
        "interval": 120,
        "timeout": 20,
        "retry_attempts": 3
      }
    },
    "failover_logic": {
      "websocket_failure": {
        "action": "switch_to_rest_api",
        "retry_websocket_after": 300
      },
      "rest_api_failure": {
        "action": "switch_to_mqtt",
        "retry_rest_api_after": 600
      },
      "mqtt_failure": {
        "action": "queue_for_sync",
        "retry_mqtt_after": 1800
      }
    }
  },
  "data_priorities": {
    "critical": {
      "level": 1,
      "protocols": ["websocket", "rest_api", "mqtt"],
      "examples": [
        "System alerts",
        "Camera offline notifications",
        "Security events"
      ]
    },
    "high": {
      "level": 2,
      "protocols": ["websocket", "rest_api"],
      "examples": [
        "Detection data",
        "Camera status updates",
        "Configuration changes"
      ]
    },
    "normal": {
      "level": 3,
      "protocols": ["websocket", "rest_api"],
      "examples": [
        "Analytics data",
        "Health metrics",
        "Log data"
      ]
    },
    "low": {
      "level": 4,
      "protocols": ["rest_api"],
      "examples": [
        "Historical data",
        "Bulk operations",
        "Reports"
      ]
    }
  },
  "error_handling": {
    "websocket_errors": {
      "connection_lost": "Retry with exponential backoff",
      "timeout": "Switch to REST API",
      "protocol_error": "Reconnect and retry"
    },
    "rest_api_errors": {
      "network_error": "Retry with exponential backoff",
      "server_error": "Switch to MQTT",
      "timeout": "Switch to MQTT"
    },
    "mqtt_errors": {
      "connection_failed": "Queue messages locally",
      "publish_failed": "Retry with QoS 1",
      "subscription_failed": "Use REST API fallback"
    }
  },
  "monitoring": {
    "metrics": [
      "connection_status",
      "message_latency",
      "success_rate",
      "fallback_frequency",
      "image_transfer_speed",
      "queue_size"
    ],
    "alerts": {
      "websocket_down": "Immediate",
      "rest_api_down": "5 minutes",
      "mqtt_down": "15 minutes",
      "image_sync_failed": "30 minutes"
    }
  }
}
