// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../dist/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum CameraStatus {
  active
  inactive
  maintenance
}

enum DetectionStatus {
  pending
  processed
  failed
}

enum ImageQuality {
  low
  medium
  high
}

enum VisualizationType {
  chart
  graph
  table
  metric
  map
}

enum AnalyticsEventCategory {
  user_interaction
  system_event
  performance
  error
  security
}

enum UserRole {
  admin
  operator
  viewer
}

// Models
model Camera {
  id                String   @id @default(uuid()) @db.Uuid
  cameraId          String   @unique @map("camera_id")
  name              String
  locationLat       Decimal? @map("location_lat") @db.Decimal(10, 8)
  locationLng       Decimal? @map("location_lng") @db.Decimal(11, 8)
  locationAddress   String?  @map("location_address")
  status            CameraStatus @default(active)
  detectionEnabled  Boolean  @default(true) @map("detection_enabled")
  imageQuality      ImageQuality @default(medium) @map("image_quality")
  uploadInterval    Int      @default(60) @map("upload_interval")
  configuration     Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  detections        Detection[]
  analytics         Analytics[]
  cameraHealth      CameraHealth[]
  systemEvents      SystemEvent[]
  analyticsEvents   AnalyticsEvent[]

  @@map("cameras")
}

model Detection {
  id           String          @id @default(uuid()) @db.Uuid
  cameraId     String          @map("camera_id") @db.Uuid
  timestamp    DateTime        @db.Timestamptz(6)
  licensePlate String          @map("license_plate")
  confidence   Decimal         @db.Decimal(3, 2)
  imageUrl     String?         @map("image_url")
  imagePath    String?         @map("image_path")
  locationLat  Decimal?        @map("location_lat") @db.Decimal(10, 8)
  locationLng  Decimal?        @map("location_lng") @db.Decimal(11, 8)
  vehicleMake  String?         @map("vehicle_make")
  vehicleModel String?         @map("vehicle_model")
  vehicleColor String?         @map("vehicle_color")
  vehicleType  String?         @map("vehicle_type")
  status       DetectionStatus @default(pending)
  metadata     Json            @default("{}")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  camera       Camera          @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@map("detections")
}

model Analytics {
  id               String   @id @default(uuid()) @db.Uuid
  cameraId         String   @map("camera_id") @db.Uuid
  date             DateTime @db.Date
  totalDetections  Int      @default(0) @map("total_detections")
  uniquePlates     Int      @default(0) @map("unique_plates")
  averageConfidence Decimal @default(0) @map("average_confidence") @db.Decimal(3, 2)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  camera           Camera   @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@unique([cameraId, date])
  @@map("analytics")
}

model CameraHealth {
  id              String   @id @default(uuid()) @db.Uuid
  cameraId        String   @map("camera_id") @db.Uuid
  timestamp       DateTime @default(now()) @db.Timestamptz(6)
  status          String
  cpuUsage        Decimal? @map("cpu_usage") @db.Decimal(5, 2)
  memoryUsage     Decimal? @map("memory_usage") @db.Decimal(5, 2)
  diskUsage       Decimal? @map("disk_usage") @db.Decimal(5, 2)
  temperature     Decimal? @db.Decimal(5, 2)
  uptimeSeconds   BigInt?  @map("uptime_seconds")
  lastDetectionAt DateTime? @map("last_detection_at") @db.Timestamptz(6)
  metadata        Json     @default("{}")

  // Relations
  camera          Camera   @relation(fields: [cameraId], references: [id], onDelete: Cascade)

  @@map("camera_health")
}

model SystemEvent {
  id        String   @id @default(uuid()) @db.Uuid
  cameraId  String?  @map("camera_id") @db.Uuid
  eventType String   @map("event_type")
  eventLevel String  @map("event_level")
  message   String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  camera    Camera?  @relation(fields: [cameraId], references: [id], onDelete: SetNull)

  @@map("system_events")
}

model Visualization {
  id              String            @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  type            VisualizationType
  configuration   Json              @default("{}")
  dataSource      String            @map("data_source")
  refreshInterval Int               @default(300) @map("refresh_interval")
  isActive        Boolean           @default(true) @map("is_active")
  createdBy       String?           @map("created_by")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  analyticsEvents AnalyticsEvent[]

  @@map("visualizations")
}

model AnalyticsEvent {
  id              String                 @id @default(uuid()) @db.Uuid
  eventType       String                 @map("event_type")
  eventCategory   AnalyticsEventCategory @map("event_category")
  userId          String?                @map("user_id") @db.Uuid
  sessionId       String?                @map("session_id")
  cameraId        String?                @map("camera_id") @db.Uuid
  visualizationId String?                @map("visualization_id") @db.Uuid
  eventData       Json                   @default("{}") @map("event_data")
  ipAddress       String?                @map("ip_address")
  userAgent       String?                @map("user_agent")
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  camera          Camera?                @relation(fields: [cameraId], references: [id], onDelete: SetNull)
  visualization   Visualization?         @relation(fields: [visualizationId], references: [id], onDelete: SetNull)
  user            User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("analytics_events")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  username  String   @unique
  password  String
  role      UserRole @default(viewer)
  firstName String?  @map("first_name")
  lastName  String?  @map("last_name")
  isActive  Boolean  @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  analyticsEvents AnalyticsEvent[]

  @@map("users")
}
