# PostgreSQL connection for backend-api (aicamera_app database).
# Copy to .env and set your real values. Do not commit .env.
# Create DB first: run server/database/init-aicamera-app.sh (requires sudo).

# Option 1: full URL (recommended)
# DATABASE_URL=postgresql://lpruser:YOUR_PASSWORD@localhost:5432/aicamera_app

# Option 2: separate vars (used if DATABASE_URL is not set)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=lpruser
# POSTGRES_PASSWORD=YOUR_PASSWORD
# POSTGRES_DB=aicamera_app

# Optional: port for backend-api (default 3000)
# PORT=3000
