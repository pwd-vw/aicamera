[Desktop Entry]
Version=1.0
Type=Application
Name=AI Camera Browser
Comment=Launch AI Camera Web Interface
Exec=chromium-browser --no-first-run --no-default-browser-check --disable-infobars --disable-notifications http://localhost/
Icon=camera
Terminal=false
Categories=Network;WebBrowser;
Keywords=AI;Camera;Browser;Interface;
StartupNotify=true
