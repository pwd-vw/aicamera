# AI Camera Edge System - Environment Configuration Template
# Copy this file to .env.production and customize for your specific installation
#
# IMPORTANT: This template contains default values suitable for most installations.
# You MUST customize the following values for your specific setup:
# - AICAMERA_ID: Unique identifier for this camera (must be unique across all cameras)
# - CHECKPOINT_ID: Location identifier for this camera
# - CAMERA_LOCATION: Human-readable location description
# - LOCATION_LAT/LOCATION_LON: GPS coordinates of camera location
# - WEBSOCKET_SERVER_URL: Server URL for data transmission (leave empty for offline mode)
# - GITHUB_TOKEN: Your GitHub personal access token (if using GitHub features)
# - GITHUB_REPO: Your repository in owner/repo format

# =============================================================================
# AI CAMERA IDENTIFICATION (REQUIRED - UNIQUE PER INSTALLATION)
# =============================================================================
# Unique identifier for this AI camera installation
AICAMERA_ID=2
# Checkpoint or location identifier
CHECKPOINT_ID=2
# Camera location name/description
CAMERA_LOCATION="Main Entrance"

# =============================================================================
# HAILO AI MODEL CONFIGURATION (REQUIRED - BASED ON YOUR DEVICE)
# =============================================================================
# Device Architecture: HAILO8 or HAILO8L (auto-detected, but can be overridden)
# HAILO_DEVICE_ARCH=HAILO8L

# AI Models - Choose based on your Hailo device architecture
# For HAILO8 devices (default for Hailo 26 TOPS):
VEHICLE_DETECTION_MODEL=yolov8n_relu6_car--640x640_quant_hailort_hailo8_1
LICENSE_PLATE_DETECTION_MODEL=yolov8n_relu6_lp--640x640_quant_hailort_hailo8_1
LICENSE_PLATE_OCR_MODEL=yolov8n_relu6_lp_ocr--256x128_quant_hailort_hailo8_1

# For HAILO8L devices ( for Hailo 13 TOPS):
#VEHICLE_DETECTION_MODEL=yolov8n_relu6_car--640x640_quant_hailort_hailo8l_1
#LICENSE_PLATE_DETECTION_MODEL=yolov8n_relu6_lp--640x640_quant_hailort_hailo8l_1
#LICENSE_PLATE_OCR_MODEL=yolov8n_relu6_lp_ocr--256x128_quant_hailort_hailo8l_1

# =============================================================================
# LOCATION CONFIGURATION (REQUIRED - GPS COORDINATES)
# =============================================================================
# GPS coordinates for this camera location
LOCATION_LAT=13.729610
LOCATION_LON=100.501443
# Location altitude (optional)
LOCATION_ALT=0

# =============================================================================
# NETWORK CONFIGURATION (OPTIONAL)
# =============================================================================
# WebSocket server URL for sending data (leave empty for offline mode)
WEBSOCKET_SERVER_URL=
# Server authentication token (if required)
WEBSOCKET_AUTH_TOKEN=
# Network timeout settings (seconds)
WEBSOCKET_TIMEOUT=30
WEBSOCKET_RETRY_INTERVAL=60

# =============================================================================
# CAMERA CONFIGURATION (OPTIONAL - DEFAULTS PROVIDED)
# =============================================================================
# Camera device path
CAMERA_DEVICE=/dev/video0
# Camera resolution (width x height) - for detection processing
CAMERA_RESOLUTION=1280x720
# Main stream resolution (width x height) - for high quality video
MAIN_RESOLUTION=1280x720
# Camera autofocus mode (0=Manual, 1=Auto, 2=Continuous)
DEFAULT_AUTOFOCUS_MODE=1
# Enable/disable autofocus (true/false) - set to false if AF_TRIGGER warnings appear
DEFAULT_AUTOFOCUS_ENABLED=true
# Low resolution stream (width x height) - for efficient processing
LORES_RESOLUTION=1280x720
# Camera frame rate
CAMERA_FPS=30
# Camera brightness (-1.0 to 1.0)
CAMERA_BRIGHTNESS=0.0
# Camera contrast (0.0 to 2.0)
CAMERA_CONTRAST=1.0
# Camera saturation (0.0 to 2.0)
CAMERA_SATURATION=1.0
# Camera sharpness (0.0 to 4.0)
CAMERA_SHARPNESS=1.0
# Auto white balance mode (0=auto, 1=fluorescent, etc.)
CAMERA_AWB_MODE=0

# =============================================================================
# DETECTION CONFIGURATION (OPTIONAL - DEFAULTS PROVIDED)
# =============================================================================
# Detection confidence threshold (0.0 to 1.0)
DETECTION_CONFIDENCE_THRESHOLD=0.8
# License plate confidence threshold (0.0 to 1.0)
PLATE_CONFIDENCE_THRESHOLD=0.5
# Detection interval (seconds)
DETECTION_INTERVAL=0.1
# Maximum detections per frame
MAX_DETECTIONS_PER_FRAME=10

# =============================================================================
# STORAGE CONFIGURATION (OPTIONAL - DEFAULTS PROVIDED)
# =============================================================================
# Image storage directory (relative to project root or absolute path)
IMAGE_SAVE_DIR=captured_images
# Database path
DATABASE_PATH=db/lpr_data.db
# Log directory
LOG_DIR=logs
# Maximum storage usage (GB)
MAX_STORAGE_GB=10
# Image retention days
IMAGE_RETENTION_DAYS=30

# =============================================================================
# SYSTEM CONFIGURATION (OPTIONAL - DEFAULTS PROVIDED)
# =============================================================================
# Flask host address
FLASK_HOST=0.0.0.0
# Flask port
FLASK_PORT=5000
# Secret key for Flask (change in production)
SECRET_KEY=your-secret-key-change-in-production
# Debug mode (true/false)
DEBUG=false
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# PERFORMANCE CONFIGURATION (OPTIONAL - DEFAULTS PROVIDED)
# =============================================================================
# Threading intervals (seconds)
SENDER_INTERVAL=60
HEALTH_SENDER_INTERVAL=300
HEALTH_CHECK_INTERVAL=3600
# Gunicorn workers
GUNICORN_WORKERS=1
# Gunicorn threads
GUNICORN_THREADS=4

# =============================================================================
# SECURITY CONFIGURATION (OPTIONAL)
# =============================================================================
# Enable authentication (true/false)
ENABLE_AUTH=false
# Admin username
ADMIN_USERNAME=admin
# Admin password (change in production)
ADMIN_PASSWORD=admin123
# API rate limiting (requests per minute)
API_RATE_LIMIT=100

# =============================================================================
# MONITORING CONFIGURATION (OPTIONAL)
# =============================================================================
# Enable system monitoring (true/false)
ENABLE_MONITORING=true
# Monitoring interval (seconds)
MONITORING_INTERVAL=60
# Alert email (optional)
ALERT_EMAIL=
# Alert threshold for storage usage (%)
STORAGE_ALERT_THRESHOLD=80

# =============================================================================
# BACKUP CONFIGURATION (OPTIONAL)
# =============================================================================
# Enable automatic backups (true/false)
ENABLE_BACKUP=false
# Backup interval (hours)
BACKUP_INTERVAL=24
# Backup retention (days)
BACKUP_RETENTION_DAYS=7
# Backup directory
BACKUP_DIR=backups

# Flask Configuration
SECRET_KEY="your-secret-key-here-change-in-production"
DEBUG="False"

# AI Camera Identification
AICAMERA_ID="1"
CHECKPOINT_ID="1"

# Device Configuration
DEVICE_ID="aicamera-edge-001"
DEVICE_MODEL="AI-CAM-EDGE-V2"
DEVICE_LOCATION="Production Location"
DEVICE_VERSION="2.0.0"

# Server Configuration
SERVER_URL="http://your-server-url:3000"
SERVER_HOST="your-server-url"
SERVER_PORT="3000"

# MQTT Configuration (Tailscale: use lprserver.tail605477.ts.net when broker is on LPR server)
MQTT_ENABLED="true"
MQTT_BROKER_HOST="lprserver.tail605477.ts.net"
MQTT_BROKER_PORT="1883"
MQTT_TOPIC_PREFIX="aicamera/edge"
MQTT_USERNAME=""
MQTT_PASSWORD=""
MQTT_KEEPALIVE="60"
MQTT_CLIENT_ID=""

# SFTP Configuration
SERVER_SFTP_ENABLED="true"
SERVER_SFTP_HOST="your-sftp-server-url"
SERVER_SFTP_PORT="22"
SERVER_SFTP_USERNAME="aicamera"
SERVER_SFTP_PASSWORD="your-sftp-password"
SERVER_SFTP_REMOTE_PATH="image_storage"

# WebSocket Configuration
WEBSOCKET_ENABLED="true"
WEBSOCKET_SERVER_URL="ws://your-server-url:3000"
WEBSOCKET_CONNECTION_TIMEOUT="30.0"
WEBSOCKET_RETRY_INTERVAL="60.0"
WEBSOCKET_MAX_RETRIES="5"
WEBSOCKET_RECONNECT_ATTEMPTS="5"
WEBSOCKET_RECONNECT_DELAY="5"

# Storage Configuration
STORAGE_MANAGER_ENABLED="true"
TRANSFER_RETRY_INTERVAL="60"
MAX_TRANSFER_RETRIES="3"
IMAGE_COMPRESSION_ENABLED="true"
IMAGE_COMPRESSION_QUALITY="85"
LOCAL_STORAGE_PATH="./captured_images"

# Paths
CAPTURED_IMAGES_PATH="captured_images"
DATABASE_PATH="db/lpr_data.db"
LOG_LEVEL="INFO"

# Heartbeat Configuration
HEARTBEAT_ENABLED="true"
HEARTBEAT_INTERVAL="30"

# Auto-startup Configuration
AUTO_START_CAMERA="true"
AUTO_START_STREAMING="true"
AUTO_START_DETECTION="true"
AUTO_START_HEALTH_MONITOR="true"
AUTO_START_WEBSOCKET_SENDER="true"
AUTO_START_STORAGE_MONITOR="true"

# Startup Delays (in seconds)
STARTUP_DELAY="5"
HEALTH_MONITOR_STARTUP_DELAY="30"
WEBSOCKET_SENDER_STARTUP_DELAY="10"
STORAGE_MONITOR_STARTUP_DELAY="5"

# Storage Monitoring Configuration
STORAGE_MONITOR_ENABLED="true"
STORAGE_MONITOR_INTERVAL="300"
STORAGE_MIN_FREE_SPACE_GB="10.0"
STORAGE_RETENTION_DAYS="7"
STORAGE_BATCH_SIZE="100"

# Experiment Configuration
EXPERIMENT_ENABLED="true"
EXPERIMENT_AUTO_SAVE="true"
EXPERIMENT_MAX_RETRIES="3"

# Communication Security
MQTT_TLS_ENABLED="false"
MQTT_TLS_CA_CERTS=""
MQTT_TLS_CERTFILE=""
MQTT_TLS_KEYFILE=""
SFTP_KEY_FILE=""
SFTP_KEY_PASSPHRASE=""

# Network Configuration
NETWORK_TIMEOUT="30"
NETWORK_RETRY_DELAY="5"
NETWORK_MAX_RETRIES="3"

# GitHub Configuration
# Copy this file to .env and fill in your actual values

# GitHub Personal Access Token
# Generate at: https://github.com/settings/tokens
# Required scopes: repo, issues, write:packages
GITHUB_TOKEN=your_github_token_here

# Repository name (owner/repo format)
# Example: username/repository-name
GITHUB_REPO=your_username/your_repository_name

# Optional: Default file path for issues
ISSUES_FILE=.github/ISSUES_FROM_PLAN.md

# =============================================================================
# INSTALLATION INSTRUCTIONS
# =============================================================================
# 1. Copy this template to .env.production:
#    cp env.production.template .env.production
#
# 2. Edit .env.production and customize the values marked as "REQUIRED" above
#
# 3. Ensure AICAMERA_ID is unique across all your camera installations
#
# 4. Set correct GPS coordinates for LOCATION_LAT and LOCATION_LON
#
# 5. Configure WEBSOCKET_SERVER_URL if you have a central server
#
# 6. Set GITHUB_TOKEN and GITHUB_REPO if using GitHub integration
#
# 7. Run the installation script: ./install.sh
#
# For more information, see the documentation in docs/edge/developer/