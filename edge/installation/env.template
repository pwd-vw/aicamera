# AI Camera Edge System - Environment Configuration Template
# Copy this file to .env and customize for your specific installation

# =============================================================================
# AI CAMERA IDENTIFICATION (REQUIRED - UNIQUE PER INSTALLATION)
# =============================================================================
# Unique identifier for this AI camera installation
AICAMERA_ID=1
# Checkpoint or location identifier
CHECKPOINT_ID=1
# Camera location name/description
CAMERA_LOCATION="Main Entrance"

# =============================================================================
# HAILO AI MODEL CONFIGURATION (REQUIRED - BASED ON YOUR DEVICE)
# =============================================================================
# Device Architecture: HAILO8 or HAILO8L (auto-detected, but can be overridden)
# HAILO_DEVICE_ARCH=HAILO8L

# AI Models - Choose based on your Hailo device architecture
# For HAILO8 devices:
# VEHICLE_DETECTION_MODEL=yolov8n_relu6_car--640x640_quant_hailort_hailo8_1
# LICENSE_PLATE_DETECTION_MODEL=yolov8n_relu6_lp--640x640_quant_hailort_hailo8_1
# LICENSE_PLATE_OCR_MODEL=yolov8n_relu6_lp_ocr--256x128_quant_hailort_hailo8_1

# For HAILO8L devices (default for Raspberry Pi 5):
VEHICLE_DETECTION_MODEL=yolov8n_relu6_car--640x640_quant_hailort_hailo8l_1
LICENSE_PLATE_DETECTION_MODEL=yolov8n_relu6_lp--640x640_quant_hailort_hailo8l_1
LICENSE_PLATE_OCR_MODEL=yolov8n_relu6_lp_ocr--256x128_quant_hailort_hailo8l_1

# =============================================================================
# LOCATION CONFIGURATION (REQUIRED - GPS COORDINATES)
# =============================================================================
# GPS coordinates for this camera location
LOCATION_LAT=13.729610
LOCATION_LON=100.501443
# Location altitude (optional)
LOCATION_ALT=0

# =============================================================================
# NETWORK CONFIGURATION (OPTIONAL)
# =============================================================================
# WebSocket server URL for sending data (leave empty for offline mode)
WEBSOCKET_SERVER_URL=
# Server authentication token (if required)
WEBSOCKET_AUTH_TOKEN=
# Network timeout settings (seconds)
WEBSOCKET_TIMEOUT=30
WEBSOCKET_RETRY_INTERVAL=60

# =============================================================================
# CAMERA CONFIGURATION (OPTIONAL - DEFAULTS PROVIDED)
# =============================================================================
# Camera device path
CAMERA_DEVICE=/dev/video0
# Camera resolution (width x height)
CAMERA_RESOLUTION=640x640
# Camera frame rate
CAMERA_FPS=30
# Camera brightness (-1.0 to 1.0)
CAMERA_BRIGHTNESS=0.0
# Camera contrast (0.0 to 2.0)
CAMERA_CONTRAST=1.0
# Camera saturation (0.0 to 2.0)
CAMERA_SATURATION=1.0
# Camera sharpness (0.0 to 4.0)
CAMERA_SHARPNESS=1.0
# Auto white balance mode (0=auto, 1=fluorescent, etc.)
CAMERA_AWB_MODE=0

# =============================================================================
# DETECTION CONFIGURATION (OPTIONAL - DEFAULTS PROVIDED)
# =============================================================================
# Detection confidence threshold (0.0 to 1.0)
DETECTION_CONFIDENCE_THRESHOLD=0.8
# License plate confidence threshold (0.0 to 1.0)
PLATE_CONFIDENCE_THRESHOLD=0.5
# Detection interval (seconds)
DETECTION_INTERVAL=0.1
# Maximum detections per frame
MAX_DETECTIONS_PER_FRAME=10

# =============================================================================
# STORAGE CONFIGURATION (OPTIONAL - DEFAULTS PROVIDED)
# =============================================================================
# Image storage directory
IMAGE_SAVE_DIR=captured_images
# Database path
DATABASE_PATH=db/lpr_data.db
# Log directory
LOG_DIR=logs
# Maximum storage usage (GB)
MAX_STORAGE_GB=10
# Image retention days
IMAGE_RETENTION_DAYS=30

# =============================================================================
# SYSTEM CONFIGURATION (OPTIONAL - DEFAULTS PROVIDED)
# =============================================================================
# Flask host address
FLASK_HOST=0.0.0.0
# Flask port
FLASK_PORT=5000
# Secret key for Flask (change in production)
SECRET_KEY=your-secret-key-change-in-production
# Debug mode (true/false)
DEBUG=false
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# PERFORMANCE CONFIGURATION (OPTIONAL - DEFAULTS PROVIDED)
# =============================================================================
# Threading intervals (seconds)
SENDER_INTERVAL=60
HEALTH_SENDER_INTERVAL=300
HEALTH_CHECK_INTERVAL=3600
# Gunicorn workers
GUNICORN_WORKERS=1
# Gunicorn threads
GUNICORN_THREADS=4

# =============================================================================
# SECURITY CONFIGURATION (OPTIONAL)
# =============================================================================
# Enable authentication (true/false)
ENABLE_AUTH=false
# Admin username
ADMIN_USERNAME=admin
# Admin password (change in production)
ADMIN_PASSWORD=admin123
# API rate limiting (requests per minute)
API_RATE_LIMIT=100

# =============================================================================
# MONITORING CONFIGURATION (OPTIONAL)
# =============================================================================
# Enable system monitoring (true/false)
ENABLE_MONITORING=true
# Monitoring interval (seconds)
MONITORING_INTERVAL=60
# Alert email (optional)
ALERT_EMAIL=
# Alert threshold for storage usage (%)
STORAGE_ALERT_THRESHOLD=80

# =============================================================================
# BACKUP CONFIGURATION (OPTIONAL)
# =============================================================================
# Enable automatic backups (true/false)
ENABLE_BACKUP=false
# Backup interval (hours)
BACKUP_INTERVAL=24
# Backup retention (days)
BACKUP_RETENTION_DAYS=7
# Backup directory
BACKUP_DIR=backups
